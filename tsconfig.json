{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src",
    "tests",
     "prisma/**/*.ts",
    "prisma.config.ts",
    "prisma/seeds/**/*.ts",
    "prisma/seed.ts",
    "vitest.config.mts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
