model Patient {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  patientCode String
  firstName String  @map("first_name")
  lastName  String? @map("last_name")
  phone     String?
  email     String?

  gender      Gender?
  dateOfBirth DateTime? @map("date_of_birth")
  bloodGroup  String?   @map("blood_group")

  maritalStatus String? @map("marital_status")
  occupation    String?
  photoUrl      String? @map("photo_url")

  isActive Boolean       @default(true) @map("is_active")
  status   PatientStatus @default(ACTIVE)
  notes    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  addresses         PatientAddress[]
  emergencyContacts PatientEmergencyContact[]
  medicalProfile    PatientMedicalProfile?
  insurances        PatientInsurance[]
  identifiers       PatientIdentifier[]
  visits            Visit[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@map("patients")
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  DECEASED
  BLOCKED
}

model PatientAddress {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  type        AddressType @default(HOME)
  addressLine String      @map("address_line")
  area        String?
  city        String?
  state       String?
  postalCode  String?     @map("postal_code")
  country     String?

  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("patient_addresses")
}

enum AddressType {
  HOME
  WORK
  OTHER
}

model PatientEmergencyContact {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name     String
  relation String?
  phone    String
  email    String?
  address  String?

  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("patient_emergency_contacts")
}

model PatientMedicalProfile {
  id        String  @id @default(uuid())
  patientId String  @unique @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  allergies          String?
  chronicDiseases    String? @map("chronic_diseases")
  currentMedications String? @map("current_medications")
  pastMedicalHistory String? @map("past_medical_history")
  familyHistory      String? @map("family_history")
  surgicalHistory    String? @map("surgical_history")
  habits             String?
  heightCm           Float?  @map("height_cm")
  weightKg           Float?  @map("weight_kg")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("patient_medical_profiles")
}

model PatientInsurance {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerName    String    @map("provider_name")
  policyNumber    String?   @map("policy_number")
  memberId        String?   @map("member_id")
  coverageDetails String?   @map("coverage_details")
  validFrom       DateTime? @map("valid_from")
  validTo         DateTime? @map("valid_to")
  isActive        Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("patient_insurances")
}

model PatientIdentifier {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  type      PatientIdentifierType
  value     String
  isPrimary Boolean               @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([patientId, type, value])
  @@index([type, value])
  @@map("patient_identifiers")
}

enum PatientIdentifierType {
  MRN
  NID
  PASSPORT
  BIRTH_CERTIFICATE
  INSURANCE_ID
  HOSPITAL_CARD
  OTHER
}

model Visit {
  id String @id @default(uuid())

  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId String @map("doctor_id")
  doctor   User   @relation(fields: [doctorId], references: [id])

  visitNumber   String  @unique @map("visit_number")
  appointmentId String? @map("appointment_id")

  type     VisitType     @default(OPD)
  status   VisitStatus   @default(SCHEDULED)
  priority VisitPriority @default(NORMAL)
  source   VisitSource   @default(DIRECT)

  chiefComplaint String? @map("chief_complaint")
  reason         String?
  symptoms       String?
  diagnosis      String?
  notes          String?

  visitDate   DateTime  @map("visit_date")
  checkedInAt DateTime? @map("checked_in_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  closedAt    DateTime? @map("closed_at")

  queueNumber  Int?    @map("queue_number")
  roomNumber   String? @map("room_number")
  departmentId String? @map("department_id")

  consultationFee Decimal? @map("consultation_fee") @db.Decimal(10, 2)
  discount        Decimal? @db.Decimal(10, 2)
  totalAmount     Decimal? @map("total_amount") @db.Decimal(10, 2)
  paidAmount      Decimal? @default(0) @map("paid_amount") @db.Decimal(10, 2)
  dueAmount       Decimal? @default(0) @map("due_amount") @db.Decimal(10, 2)

  followUpDate       DateTime? @map("follow_up_date")
  referredToDoctorId String?   @map("referred_to_doctor_id")

  createdById String? @map("created_by_id")
  updatedById String? @map("updated_by_id")

  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("visits")
}

enum VisitType {
  OPD // outdoor / chamber visit
  IPD // admitted patient visit
  EMERGENCY // emergency case
  FOLLOW_UP // revisit after previous consultation
  TELEMEDICINE // online consultation
  HOME_VISIT // doctor home service
  DAY_CARE // short procedure / observation
  LAB_ONLY // only lab / diagnostics
  PROCEDURE // injection, dressing, small procedure
}

enum VisitStatus {
  SCHEDULED // appointment booked
  CHECKED_IN // patient arrived
  WAITING // waiting for doctor
  IN_CONSULTATION // doctor is seeing patient
  ON_HOLD // temporary paused
  REFERRED // referred to another doctor/department
  ADMITTED // converted to IPD
  LAB_PENDING // waiting for test/report
  COMPLETED // consultation finished
  CANCELLED // cancelled before completion
  NO_SHOW // patient did not come
  CLOSED // fully settled, billing + visit closed
}

enum VisitPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum VisitSource {
  DIRECT
  APPOINTMENT
  EMERGENCY
  REFERRAL
  WALK_IN
}
