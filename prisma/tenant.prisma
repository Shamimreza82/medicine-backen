enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
  ARCHIVED
}



model Tenant {
  id              String        @id @default(uuid())
  tenantTypeId    String?       @map("tenant_type_id")

  name            String
  slug            String        @unique
  code            String?       @unique

  email           String        @unique
  phone           String?
  website         String?
  logoUrl         String?       @map("logo_url")

  status          TenantStatus  @default(PENDING)

  ownerUserId     String?       @map("owner_user_id")

  isTrial         Boolean       @default(true) @map("is_trial")
  trialStartsAt   DateTime?     @map("trial_starts_at")
  trialEndsAt     DateTime?     @map("trial_ends_at")

  activatedAt     DateTime?     @map("activated_at")
  suspendedAt     DateTime?     @map("suspended_at")
  archivedAt      DateTime?     @map("archived_at")

  metadata        Json?         // fully generic tenant-level metadata
  deletedAt       DateTime?

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenantType      TenantType?   @relation(fields: [tenantTypeId], references: [id], onDelete: SetNull)

  setting         TenantSetting?
  features        TenantFeature[]
  subscriptions   TenantSubscription[]
  usages          TenantUsage[]
  limits          TenantLimit[]
  invoices BillingInvoice[]    
  payments BillingPayment[]     

  users           User[]
  roles           Role[]

  auditLogs       AuditLog[]
  activityLogs    ActivityLog[]
  files           File[]
  webhookEndpoints WebhookEndpoint[]

  @@index([tenantTypeId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("tenants")
}




model TenantType {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  metadata    Json?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenants     Tenant[]

  @@map("tenant_types")
}






model TenantSetting {
  id                     String    @id @default(uuid())
  tenantId               String    @unique @map("tenant_id")
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  timezone               String    @default("UTC")
  currency               String    @default("USD")
  language               String    @default("en")
  dateFormat             String    @default("YYYY-MM-DD") @map("date_format")
  timeFormat             String    @default("24h") @map("time_format")

  sessionTimeoutMinutes  Int       @default(60) @map("session_timeout_minutes")
  require2FA             Boolean   @default(false) @map("require_2fa")
  allowCustomBranding    Boolean   @default(true) @map("allow_custom_branding")

  primaryColor           String?   @map("primary_color")
  secondaryColor         String?   @map("secondary_color")
  faviconUrl             String?   @map("favicon_url")

  customConfig           Json?     @map("custom_config")

  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("tenant_settings")
}






model Feature {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?
  category    String?
  metadata    Json?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenantFeatures TenantFeature[]

  @@map("features")
}



model TenantFeature {
  id         String    @id @default(uuid())
 
  featureId  String    @map("feature_id")
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature    Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)

  enabled    Boolean   @default(false)
  config     Json?
  startsAt   DateTime? @map("starts_at")
  endsAt     DateTime? @map("ends_at")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, featureId])
  @@index([tenantId])
  @@index([featureId])
  @@map("tenant_features")
}
