model Tenant {
  id     String       @id @default(uuid())
  name   String
  slug   String       @unique
  code   String?      @unique
  status TenantStatus @default(PENDING)

  email   String?
  phone   String?
  logoUrl String?
  address String?

  ownerUserId String? @map("owner_user_id")
  ownerUser   User?   @relation("TenantOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  isTrial       Boolean   @default(true) @map("is_trial")
  trialStartsAt DateTime? @map("trial_starts_at")
  trialEndsAt   DateTime? @map("trial_ends_at")

  activatedAt DateTime? @map("activated_at")
  suspendedAt DateTime? @map("suspended_at")
  archivedAt  DateTime? @map("archived_at")

  metadata  Json?
  deletedAt DateTime? @map("deleted_at")

  users         User[]
  patients      Patient[]
  subscriptions Subscription[]
  settings      TenantSetting?

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  activityLogs ActivityLog[]
  auditLogs    AuditLog[]
  doctors      Doctor[]
  files        File[]

  @@map("tenants")
}

model TenantSetting {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  prescriptionHeader  String? @map("prescription_header")
  prescriptionFooter  String? @map("prescription_footer")
  defaultFollowUpDays Int?    @map("default_follow_up_days")

  timezone String @default("Asia/Dhaka")
  currency String @default("BDT")
  language String @default("en")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
  ARCHIVED
}
