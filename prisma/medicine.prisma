model Company {
  id           Int           @id
  name         String
  order        Int           @default(0)
  brands       DrugBrand[]
  herbalBrands HerbalBrand[]

  @@map("t_company_name")
}

model DrugGeneric {
  id                    Int                  @id
  name                  String
  indication            String?
  administration        String?
  adultDose             String?              @map("adult_dose")
  childDose             String?              @map("child_dose")
  contraIndication      String?              @map("contra_indication")
  interaction           String?
  modeOfAction          String?              @map("mode_of_action")
  precaution            String?
  pregnancyCategoryId   Int?                 @map("pregnancy_category_id")
  pregnancyCategoryNote String?              @map("pregnancy_category_note")
  renalDose             String?              @map("renal_dose")
  sideEffect            String?              @map("side_effect")
  brands                DrugBrand[]
  pregnancyCategory     PregnancyCategory?   @relation(fields: [pregnancyCategoryId], references: [id])
  indicationGenerics    IndicationGeneric[]
  sponsoredBrands       SponsoredBrand[]
  therapeuticGenerics   TherapeuticGeneric[]

  @@map("t_drug_generic")
}

model DrugBrand {
  id              Int              @id
  name            String
  companyId       Int              @map("company_id")
  genericId       Int              @map("generic_id")
  form            String?
  packSize        String?          @map("packsize")
  price           String?
  strength        String?
  isSponsored     Boolean          @default(false) @map("is_sponsored")
  company         Company          @relation(fields: [companyId], references: [id])
  generic         DrugGeneric      @relation(fields: [genericId], references: [id])
  sponsoredBrands SponsoredBrand[]

  @@map("t_drug_brand")
}

model HerbalGeneric {
  id                 Int           @id
  name               String
  composition        String?
  contraindication   String?
  description        String?
  dosage             String?
  drugInteraction    String?       @map("drug_interaction")
  indication         String?
  modeOfActions      String?       @map("mode_of_actions")
  precaution         String?
  pregnancyLactation String?       @map("pregnancy_lactation")
  sideEffects        String?       @map("side_effects")
  therapeuticClass   String?       @map("therapeutic_class")
  brands             HerbalBrand[]

  @@map("t_herbal_generic")
}

model HerbalBrand {
  id        Int           @id
  name      String
  companyId Int           @map("company_id")
  genericId Int           @map("generic_id")
  form      String?
  packSize  String?       @map("packsize")
  price     String?
  strength  String?
  company   Company       @relation(fields: [companyId], references: [id])
  generic   HerbalGeneric @relation(fields: [genericId], references: [id])

  @@map("t_herbal_brand")
}

model Indication {
  id                 Int                 @id
  name               String              @unique
  indicationGenerics IndicationGeneric[]

  @@map("t_indication")
}

model PregnancyCategory {
  id          Int           @id
  name        String
  description String?
  generics    DrugGeneric[]

  @@map("t_pregnancy_category")
}

model Systemic {
  id           Int           @id
  name         String
  parentId     Int?          @map("systemic_parent_id")
  parent       Systemic?     @relation("SystemicHierarchy", fields: [parentId], references: [id])
  children     Systemic[]    @relation("SystemicHierarchy")
  therapeutics Therapeutic[]

  @@map("t_systemic")
}

model Therapeutic {
  id                  Int                  @id
  name                String
  systemicClassId     Int                  @map("systemic_category_id")
  systemicClass       Systemic             @relation(fields: [systemicClassId], references: [id])
  therapeuticGenerics TherapeuticGeneric[]

  @@map("t_therapitic")
}

model IndicationGeneric {
  id           Int         @id
  genericId    Int         @map("generic_id")
  indicationId Int         @map("indication_id")
  generic      DrugGeneric @relation(fields: [genericId], references: [id])
  indication   Indication  @relation(fields: [indicationId], references: [id])

  @@map("t_indication_generic_index")
}

model TherapeuticGeneric {
  id            Int         @id
  genericId     Int         @map("generic_id")
  therapeuticId Int         @map("therapitic_id")
  generic       DrugGeneric @relation(fields: [genericId], references: [id])
  therapeutic   Therapeutic @relation(fields: [therapeuticId], references: [id])

  @@map("t_therapitic_generic")
}

model SponsoredBrand {
  brandId   Int         @map("brand_id")
  genericId Int         @map("generic_id")
  brand     DrugBrand   @relation(fields: [brandId], references: [id])
  generic   DrugGeneric @relation(fields: [genericId], references: [id])

  @@id([brandId, genericId])
  @@map("t_sponsored_brand")
}
