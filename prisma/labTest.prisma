
model LabTest {
  id            String       @id @default(uuid())
  name          String       @unique
  slug          String       @unique
  shortName     String?      @map("short_name")
  category      String? 
  description   String?
  specimen      String?      // Blood, Urine, Stool, etc.
  preparation   String?      // Fasting required, morning sample, etc.
  normalRange   String?      @map("normal_range")
  unit          String?
  isActive      Boolean      @default(true) @map("is_active")
  metadata      Json?


  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([name])
  @@index([slug])
  @@index([category])
  @@map("lab_tests")
}

